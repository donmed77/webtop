# =============================================================================
# Cloud Browser — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# Admin credentials
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Timezone
TZ=UTC

# Docker Compose project name (namespaces volumes, networks, container names)
# Production: cloud-browser
# Dev:        dev-cloud-browser
COMPOSE_PROJECT_NAME=cloud-browser

# Container naming prefix (isolates session containers between environments)
# Production: session       → creates session-XXXXXXXX containers
# Dev:        dev-session   → creates dev-session-XXXXXXXX containers
CONTAINER_PREFIX=session

# Docker network name (isolates container networking between environments)
# Production: cloud-browser-isolated
# Dev:        dev-cloud-browser-isolated
NETWORK_NAME=cloud-browser-isolated

# Project root path (for mounting browser scripts/assets into session containers)
# Production: /root/apps/webtop
# Dev:        /root/apps/webtop-dev
PROJECT_ROOT=/root/apps/webtop

# Host-side ports (must not overlap between environments)
# Production: 3005 / 3002 / 6379
# Dev:        3006 / 3003 / 6380
BACKEND_PORT=3005
FRONTEND_PORT=3002
REDIS_PORT=6379

# Session container port range (must not overlap between environments)
# Production: 4000–4200
# Dev:        5000–5200
PORT_RANGE_START=4000
PORT_RANGE_END=4200

# Browser container image
# Production: webtop-browser:latest
# Dev:        dev-webtop-browser:latest
CONTAINER_IMAGE=webtop-browser:latest

# URLs
# Production: https://unshortlink.com
# Dev:        https://dev.unshortlink.com
FRONTEND_URL=https://unshortlink.com
NEXT_PUBLIC_API_URL=https://unshortlink.com/api
